# DuckDB warehouse path (relative to project root)
DUCKDB_PATH=data/warehouse.duckdb

# FastAPI server
API_HOST=0.0.0.0
API_PORT=8000

# Streamlit → API base URL (override to http://api:8000 in Docker)
API_BASE_URL=http://localhost:8000

# Text2SQL backend: "rule_based" (no API key needed) or "openai"
LLM_PROVIDER=rule_based
OPENAI_API_KEY=your_key_here

# Logging
LOG_LEVEL=INFO

# Query safety limits
MAX_ROWS=10000
QUERY_TIMEOUT=30

# Data paths
SAMPLE_DATA_PATH=data/sample
METADATA_CATALOG_PATH=data/metadata/catalog.yaml

# Sample data generation
SAMPLE_SEED=42
SAMPLE_CUSTOMERS=300
SAMPLE_PRODUCTS=100
SAMPLE_ORDERS=750
